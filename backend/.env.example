# Database
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"
# Supabase Auth
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-from-dashboard"

# AI Services
GEMINI_API_KEY="your-gemini-api-key"

# Google Services
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
GOOGLE_MAPS_DIRECTIONS_API_KEY="your-google-maps-directions-api-key"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Weather
OPENWEATHER_API_KEY="your-openweather-api-key"

# Spotify (Optional - Iteration 4)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

# Application
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"

# CORS
CORS_ORIGIN="http://localhost:5173"
