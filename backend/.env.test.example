# Copy to .env.test before running backend tests locally.
# Requires Docker test DB — see backend/test/README.md.

NODE_ENV=test

# Local Docker test database (postgres:16 on port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/routiq_test
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/routiq_test

# Test-only secrets — never use production values
JWT_SECRET=test-jwt-secret-local-only
JWT_REFRESH_SECRET=test-refresh-secret-local-only

# Dummy Supabase values — backend tests do not call Supabase
SUPABASE_URL=https://example.invalid
SUPABASE_SERVICE_ROLE_KEY=fake-supabase-service-role-key-not-a-real-jwt
SUPABASE_JWT_SECRET=fake-supabase-jwt-secret-local-only
