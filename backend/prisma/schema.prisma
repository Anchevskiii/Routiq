generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @db.Uuid
  email            String           @unique
  name             String
  avatarUrl        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  lastLoginAt      DateTime?
  metadata         Json?            @default("{}")
  activityLogs     ActivityLog[]
  calendarExports  CalendarExport[]
  comments         Comment[]
  invitedBy        GroupMember[]    @relation("InvitedByUser")
  groupMemberships GroupMember[]
  createdGroups    Group[]          @relation("GroupCreator")
  itineraries      Itinerary[]
  votes            Vote[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Itinerary {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  destination      String
  startDate        DateTime         @db.Date
  endDate          DateTime         @db.Date
  travelType       TravelType
  shareToken       String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  aiModel          String?
  aiPromptHash     String?
  bestSeason       String?
  estimatedBudget  String?
  generatedAt      DateTime?
  generationTimeMs Int?
  isPublic         Boolean          @default(false)
  totalDays        Int
  calendarExports  CalendarExport[]
  groupItineraries GroupItinerary[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  days             ItineraryDay[]
  generalTips      ItineraryTip[]

  @@index([userId])
  @@index([destination])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@map("itineraries")
}

model ItineraryDay {
  id          String                    @id @default(uuid()) @db.Uuid
  itineraryId String                    @db.Uuid
  dayNumber   Int
  date        DateTime                  @db.Date
  theme       String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  deletedAt   DateTime?
  activities  ItineraryActivity[]
  itinerary   Itinerary                 @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  weather     ItineraryWeatherSnapshot?

  @@unique([itineraryId, dayNumber])
  @@index([itineraryId])
  @@map("itinerary_days")
}

model ItineraryActivity {
  id              String       @id @default(uuid()) @db.Uuid
  dayId           String       @db.Uuid
  activityType    ActivityType @default(ATTRACTION)
  sortOrder       Int
  title           String
  description     String?
  location        String?
  address         String?
  startTime       String?
  durationMinutes Int?
  cost            String?
  tips            String?
  latitude        Float?
  longitude       Float?
  placeId         String?
  mealType        String?
  priceRange      String?
  transportMethod String?
  transportCost   String?
  transportNotes  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  day             ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([activityType])
  @@index([placeId])
  @@map("itinerary_activities")
}

model ItineraryWeatherSnapshot {
  id             String       @id @default(uuid()) @db.Uuid
  dayId          String       @unique @db.Uuid
  condition      String
  tempMin        Float?
  tempMax        Float?
  humidity       Int?
  windSpeed      Float?
  precipitation  Float?
  iconCode       String?
  recommendation String?
  fetchedAt      DateTime     @default(now())
  day            ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("itinerary_weather_snapshots")
}

model ItineraryTip {
  id          String    @id @default(uuid()) @db.Uuid
  itineraryId String    @db.Uuid
  sortOrder   Int
  content     String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
  @@map("itinerary_tips")
}

model Group {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  imageUrl     String?
  themeColor   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  createdById  String           @db.Uuid
  activityLogs ActivityLog[]
  itineraries  GroupItinerary[]
  members      GroupMember[]
  comments     Comment[]
  createdBy    User             @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@map("groups")
}

model GroupMember {
  id          String           @id @default(uuid()) @db.Uuid
  groupId     String           @db.Uuid
  userId      String           @db.Uuid
  role        GroupRole        @default(MEMBER)
  joinedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  invitedAt   DateTime         @default(now())
  invitedById String?          @db.Uuid
  respondedAt DateTime?
  status      InvitationStatus @default(PENDING)
  updatedAt   DateTime         @updatedAt
  group       Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy   User?            @relation("InvitedByUser", fields: [invitedById], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@index([status])
  @@map("group_members")
}

model GroupItinerary {
  id          String    @id @default(uuid()) @db.Uuid
  groupId     String    @db.Uuid
  itineraryId String    @db.Uuid
  addedAt     DateTime  @default(now())
  deletedAt   DateTime?
  addedById   String    @db.Uuid
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@unique([groupId, itineraryId])
  @@index([groupId])
  @@index([itineraryId])
  @@map("group_itineraries")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  groupId   String    @db.Uuid
  userId    String    @db.Uuid
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  parentId  String?   @db.Uuid
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model Vote {
  id               String         @id @default(uuid()) @db.Uuid
  groupItineraryId String         @db.Uuid
  userId           String         @db.Uuid
  voteType         VoteType       @default(UPVOTE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  groupItinerary   GroupItinerary @relation(fields: [groupItineraryId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupItineraryId, userId])
  @@index([groupItineraryId])
  @@index([userId])
  @@map("votes")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @db.Uuid
  userId    String   @db.Uuid
  action    String
  details   Json?
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model CalendarExport {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  itineraryId String       @db.Uuid
  format      ExportFormat
  exportedAt  DateTime     @default(now())
  itinerary   Itinerary    @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itineraryId])
  @@map("calendar_exports")
}

enum TravelType {
  CULTURAL
  GASTRONOMIC
  NATURE
  ADVENTURE
  RELAX
}

enum GroupRole {
  ADMIN
  MEMBER
  OWNER
  MODERATOR
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum ActivityType {
  ATTRACTION
  MEAL
  TRANSPORT
  FREE_TIME
  ACCOMMODATION
}

enum ExportFormat {
  ICS
  PDF
}
